#!/usr/bin/env bash
# nmapz — two-phase TCP nmap wrapper (discovery → full scan)

R=$'\033[0m'
BOLD=$'\033[1m'
DIM=$'\033[2m'
CYAN=$'\033[1;36m'
GREEN=$'\033[1;32m'
YELLOW=$'\033[0;33m'
RED=$'\033[1;31m'
GRAY=$'\033[0;90m'
WHITE=$'\033[1;37m'
MAGENTA=$'\033[1;35m'

usage() {
    echo ""
    printf "${CYAN}${BOLD}nmapz${R} — two-phase TCP nmap wrapper\n\n"
    printf "${WHITE}Usage:${R}   nmapz [options] <target> <scanname>\n\n"
    printf "${WHITE}Modes:${R}\n"
    printf "  ${CYAN}(default)${R}      Auto-chain: fast discovery → full scan on found ports\n"
    printf "  ${YELLOW}-p <ports>${R}     Skip discovery, run full scan on specified ports only\n"
    printf "  ${MAGENTA}-x${R}             Xmas scan discovery → full scan on found ports\n\n"
    printf "${WHITE}Options:${R}\n"
    printf "  ${YELLOW}-h${R}             Show this help\n\n"
    printf "${WHITE}Examples:${R}\n"
    printf "  nmapz 10.10.10.1 initial\n"
    printf "  nmapz -p 22,80,443 10.10.10.1 targeted\n"
    printf "  nmapz -x 10.10.10.1 xmas\n\n"
    printf "${DIM}Output saved to ./nmap/ relative to current working directory${R}\n\n"
    exit 1
}

# Extract open TCP ports from a .gnmap file
parse_ports() {
    grep -oP '\d+(?=/open/tcp)' "$1" | sort -n | paste -sd','
}

# Phase banner
phase_banner() {
    local num="$1" label="$2" outfile="$3"; shift 3
    echo ""
    printf "${CYAN}${BOLD}── Phase %s: %s${R}\n" "$num" "$label"
    printf "  ${GRAY}Command  ${DIM}nmap %s -oA %s${R}\n" "$*" "$outfile"
    printf "  ${GRAY}Output   ${WHITE}%s${DIM}.{nmap,xml,gnmap}${R}\n\n" "$outfile"
}

run_discovery() {
    local target="$1" outfile="$2" mode="$3"
    local -a flags label

    if [[ "$mode" == "xmas" ]]; then
        flags=(-sX -T4 -p- --open -n -Pn)
        label="Xmas Discovery"
    else
        flags=(-sS -T4 -p- --open -n -Pn)
        label="Discovery"
    fi

    phase_banner "1" "$label" "$outfile" "${flags[@]}"
    "${SUDO[@]}" nmap "${flags[@]}" -oA "$outfile" "$target"
}

run_full() {
    local target="$1" ports="$2" outfile="$3" phase="$4"
    local -a flags=(-sS -T4 -sC -sV -O -Pn -p "$ports")

    phase_banner "$phase" "Full Scan" "$outfile" "${flags[@]}"
    "${SUDO[@]}" nmap "${flags[@]}" -oA "$outfile" "$target"
}

# ── Argument parsing ──────────────────────────────────────────────────────────

xmas=false
ports_override=""

while getopts ":p:xh" opt; do
    case $opt in
        p) ports_override="$OPTARG" ;;
        x) xmas=true ;;
        h) usage ;;
        :) printf "${RED}Error: -%s requires an argument.${R}\n\n" "$OPTARG" >&2; usage ;;
        *) printf "${RED}Error: unknown option -%s${R}\n\n" "$OPTARG" >&2; usage ;;
    esac
done
shift $((OPTIND - 1))

[[ $# -lt 2 ]] && usage

target="$1"
scanname="$2"
outdir="$(pwd)/nmap"
mkdir -p "$outdir"

[[ $EUID -eq 0 ]] && SUDO=() || SUDO=(sudo)

# ── Header ────────────────────────────────────────────────────────────────────

echo ""
printf "${CYAN}${BOLD}[nmapz]${R}\n"
printf "  ${GRAY}Target   ${WHITE}%s${R}\n" "$target"
printf "  ${GRAY}Outdir   ${WHITE}%s${R}\n" "$outdir"

# ── Mode: direct full scan (-p) ───────────────────────────────────────────────

if [[ -n "$ports_override" ]]; then
    printf "  ${GRAY}Mode     ${YELLOW}direct — ports: %s${R}\n" "$ports_override"

    run_full "$target" "$ports_override" "${outdir}/${scanname}" "1"
    status=$?

# ── Mode: xmas auto-chain (-x) ────────────────────────────────────────────────

elif [[ "$xmas" == true ]]; then
    printf "  ${GRAY}Mode     ${MAGENTA}xmas discovery → full scan${R}\n"

    run_discovery "$target" "${outdir}/${scanname}_xmas" "xmas"
    [[ $? -ne 0 ]] && { printf "\n${RED}Xmas scan failed. Aborting.${R}\n\n"; exit 1; }

    ports=$(parse_ports "${outdir}/${scanname}_xmas.gnmap")

    if [[ -z "$ports" ]]; then
        printf "\n${YELLOW}No open ports found via xmas scan.${R}\n\n"
        exit 0
    fi

    printf "\n${GREEN}${BOLD}Open ports found:${R} ${WHITE}%s${R}\n" "$ports"
    run_full "$target" "$ports" "${outdir}/${scanname}_full" "2"
    status=$?

# ── Mode: default auto-chain ──────────────────────────────────────────────────

else
    printf "  ${GRAY}Mode     ${CYAN}discovery → full scan${R}\n"

    run_discovery "$target" "${outdir}/${scanname}_discovery" "syn"
    [[ $? -ne 0 ]] && { printf "\n${RED}Discovery scan failed. Aborting.${R}\n\n"; exit 1; }

    ports=$(parse_ports "${outdir}/${scanname}_discovery.gnmap")

    if [[ -z "$ports" ]]; then
        printf "\n${YELLOW}No open ports found.${R}\n\n"
        exit 0
    fi

    printf "\n${GREEN}${BOLD}Open ports found:${R} ${WHITE}%s${R}\n" "$ports"
    run_full "$target" "$ports" "${outdir}/${scanname}_full" "2"
    status=$?
fi

# ── Done ──────────────────────────────────────────────────────────────────────

echo ""
if [[ $status -eq 0 ]]; then
    printf "${GREEN}${BOLD}Done.${R}  Results in ${WHITE}%s/${R}\n\n" "$outdir"
else
    printf "${RED}nmap exited with status %d${R}\n\n" "$status"
fi
exit $status
